// secrets.h — copy to secrets.h (gitignored) and fill in before flashing.
// Used by the buddy app for WiFi + the max-side server.
#pragma once

#define WIFI_SSID        "your-ssid"
#define WIFI_PASSWORD    "your-wifi-password"

// max-side server (server/). Use the LAN IP or Tailscale name reachable from the board.
// Endpoints: POST <BUDDY_SERVER_URL>/transcribe   GET <BUDDY_SERVER_URL>/display
#define BUDDY_SERVER_URL "http://10.0.0.72:8810"

// Shared secret — must match BUDDY_TOKEN in server/.env. Sent as the X-Buddy-Token header.
#define BUDDY_TOKEN      "change-me-to-a-long-random-hex"

// How often to refresh the e-paper from /display, in seconds (e-paper full refresh is slow).
#define DISPLAY_POLL_SECONDS 60
