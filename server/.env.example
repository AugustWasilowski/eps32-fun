# Copy to .env and fill in. Keep .env out of git (it's gitignored).

# Shared secret with the firmware (secrets.h BUDDY_TOKEN). Sent as X-Buddy-Token.
BUDDY_TOKEN=change-me-to-a-long-random-hex

# voice-channel endpoint + its X-Webhook-Token (voice-channel/.env on max).
VOICE_CHANNEL_URL=http://host.docker.internal:8803/
VOICE_CHANNEL_TOKEN=change-me-matches-voice-channel-env

# Whisper
WHISPER_MODEL=small.en
WHISPER_DEVICE=cuda
WHISPER_COMPUTE=float16

# Context % math: the model's window for the ss-channels session.
# 200000 for standard, 1000000 if Max runs the 1M-context model.
CONTEXT_WINDOW=200000
SS_PROJECT_DIR=-home-mayorawesome
# Optional: pin the exact session transcript instead of "most recently modified".
# SS_SESSION_JSONL=/root/.claude/projects/-home-mayorawesome/<id>/<session>.jsonl
