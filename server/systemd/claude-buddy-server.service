# Optional non-docker unit. Prefer docker-compose.yml unless you want bare-metal.
# Install: cp to ~/.config/systemd/user/ ; systemctl --user enable --now claude-buddy-server
[Unit]
Description=Claude Buddy server (ESP32 e-paper voice/display backend)
After=network-online.target

[Service]
WorkingDirectory=%h/eps32-fun/server
EnvironmentFile=%h/eps32-fun/server/.env
ExecStart=%h/eps32-fun/server/.venv/bin/uvicorn buddy_server:app --host 0.0.0.0 --port 8810
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
